// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ghm cli > --help 1`] = `
"ghm/0.0.0

Usage:
  $ ghm <command> [options]

Commands:
  setup          Setup config and shell integration for ghm
  clone <repo>   Clone a repository to <root>/<owner>/<repo>
  list           List repositories under configured root
  shell <shell>  Generate shell integration code

For more info, run any command with the \`--help\` flag:
  $ ghm setup --help
  $ ghm clone --help
  $ ghm list --help
  $ ghm shell --help

Options:
  -c, --config <path>  Use a custom config file path 
  -h, --help           Display this message 
  -v, --version        Display version number 
"
`;
