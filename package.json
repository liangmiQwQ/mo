{
  "name": "@liangmi/ghm",
  "version": "0.0.0",
  "description": "Project manager for opensource developers on Github",
  "homepage": "https://github.com/liangmiQwQ/ghm#readme",
  "bugs": {
    "url": "https://github.com/liangmiQwQ/ghm/issues"
  },
  "license": "MIT",
  "author": "Liang Mi <hi@liangmi.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liangmiQwQ/ghm.git"
  },
  "bin": {
    "ghm": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "tsx src/cli.ts",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@posva/prompts": "^2.4.4",
    "cac": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.13"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
