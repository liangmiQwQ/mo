{
  "name": "@liangmi/mo",
  "version": "0.0.5",
  "description": "Manage your open source projects",
  "homepage": "https://github.com/liangmiQwQ/mo#readme",
  "bugs": {
    "url": "https://github.com/liangmiQwQ/mo/issues"
  },
  "license": "MIT",
  "author": "Liang Mi <hi@liangmi.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liangmiQwQ/mo.git"
  },
  "bin": {
    "mo": "./bin/mo.mjs",
    "mo-inner": "./bin/mo-inner.mjs"
  },
  "files": [
    "dist",
    "bin",
    "scripts",
    "config_schema.json"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev:i": "tsx scripts/install.ts",
    "dev:uni": "tsx scripts/uninstall.ts",
    "preview": "node bin/cli.mjs",
    "test": "vp test run",
    "check": "vp check",
    "clean": "rm -rf .root/*",
    "prepublishOnly": "vp run build",
    "prepare": "vp config",
    "release": "bumpp"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/which": "^3.0.4",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "cac": "^7.0.0",
    "ink": "^6.8.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "tinyexec": "^1.0.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "untildify": "^6.0.0",
    "vite-plus": "^0.1.15",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.15",
    "which": "^6.0.1"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "inlinedDependencies": {
    "cac": "7.0.0",
    "picocolors": "1.1.1",
    "untildify": "6.0.0"
  }
}
